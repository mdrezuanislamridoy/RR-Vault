model SubscriptionPlan {
    id              String           @id @default(uuid())
    name            String
    description     String
    isPopular       Boolean          @default(false)
    planIncludes    String[]
    autoRenew       Boolean          @default(false)
    pricings        PackagePricing[]
    stripeProductId String

    subscriptions Subscribed[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    histories SubscriptionPaymentPlanHistory[]
}

model PackagePricing {
    id                 String           @id @default(uuid())
    price              Float
    maxStorage         BigInt
    maxFiles           Int
    stripePriceId      String
    billingCycle       BillingCycle     @default(MONTHLY)
    subscriptionPlan   SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id])
    subscriptionPlanId String

    subscriptions Subscribed[]
    histories     SubscriptionPaymentPlanHistory[]
}

model SubscriptionPaymentPlanHistory {
    id                 String             @id @default(uuid())
    userId             String
    subscriptionPlanId String
    packagePricingId   String
    isActive           Boolean            @default(true)
    status             SubscriptionStatus
    createdAt          DateTime           @default(now())
    updatedAt          DateTime           @updatedAt

    user           User             @relation(fields: [userId], references: [id])
    plan           SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id])
    packagePricing PackagePricing   @relation(fields: [packagePricingId], references: [id])
}

model Subscribed {
    id                   String             @id @default(uuid())
    userId               String
    subscriptionPlanId   String
    packagePricingId     String
    stripeSubscriptionId String?            @unique
    isActive             Boolean            @default(true)
    status               SubscriptionStatus
    storageUsed          BigInt             @default(0)
    storageLimit         BigInt             @default(0)
    fileUploaded         Int                @default(0)
    fileLimit            Int                @default(0)
    billingCycle         BillingCycle       @default(MONTHLY)
    currentPeriodStart   DateTime?
    currentPeriodEnd     DateTime?
    createdAt            DateTime           @default(now())
    updatedAt            DateTime           @updatedAt

    // relations
    user    User             @relation(fields: [userId], references: [id])
    plan    SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id])
    package PackagePricing   @relation(fields: [packagePricingId], references: [id])
}

enum SubscriptionStatus {
    PENDING
    PAID
    CANCELLED
    FAILED
}

enum BillingCycle {
    MONTHLY
    YEARLY
}
