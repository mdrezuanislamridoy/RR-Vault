model CloudSecret {
    id String @id @unique @default(uuid())

    api_key    String
    api_secret String?
    app_data AppData[]
    userId     String   @unique
    user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    created_at DateTime @default(now())
}

model AppData {
    id String @id @unique @default(uuid())
    name String
    appId String
    cloudSecret CloudSecret @relation(fields: [cloudSecretId], references: [id], onDelete: Cascade)
    cloudSecretId String
}

model StoredFile {
    id String @id @unique @default(uuid())

    folderName String?
    fileUrl String
    shortenUrl ShortenUrl?
    fileKey String
    userId String
    user User @relation(fields:[userId], references:[id], onDelete: Cascade)
    uploadedAt DateTime @default(now())
}
